generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String    @id 
  activeStreak    Int       @default(0)
  longestStreak   Int       @default(0)
  totalDays       Int       @default(0)
  lastPrayerDate  DateTime? @db.Date
  currentBook     String    @default("Mateo")
  currentChapter  Int       @default(1)
  currentPsalm    Int       @default(1)
  createdAt       DateTime  @default(now())
  timerPreference Int       @default(20)
  
  
  prayers         Prayer[]
}

model Prayer {
  id              String   @id @default(uuid())
  userId          String
  durationMinutes Int
  completedAt     DateTime @default(now())
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}